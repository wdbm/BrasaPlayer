    def on_close_request(self, *_args):
        if self.tick_id:
            GLib.source_remove(self.tick_id)
            self.tick_id = 0
        if self.status_message_timeout:
            GLib.source_remove(self.status_message_timeout)
            self.status_message_timeout = 0
        if self.cursor_hide_timeout:
            GLib.source_remove(self.cursor_hide_timeout)
            self.cursor_hide_timeout = 0
        self.sync_session_inhibit(force_release=True)
        self.disconnect_media_stream()
        return False

    def on_motion(self, *_args):
        if not self.is_fullscreen_mode:
            return
        self.show_mouse_cursor()
        if self.fullscreen_controls_visible:
            if self.cursor_hide_timeout:
                GLib.source_remove(self.cursor_hide_timeout)
                self.cursor_hide_timeout = 0
            return
        self.schedule_cursor_hide()

    def on_video_pressed(self, _gesture, n_press, _x, _y):
        if n_press == 2:
            self.on_toggle_fullscreen_action()

    def on_fullscreen_changed(self, *_args):
        self.is_fullscreen_mode = self.props.fullscreened
        if self.is_fullscreen_mode:
            self.fullscreen_controls_visible = False
        self.header_bar.set_visible(not self.is_fullscreen_mode)
        self.update_controls_visibility()
        if self.cursor_hide_timeout:
            GLib.source_remove(self.cursor_hide_timeout)
            self.cursor_hide_timeout = 0
        self.show_mouse_cursor()
        if self.is_fullscreen_mode:
            self.schedule_cursor_hide()

