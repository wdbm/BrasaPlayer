def collect_startup_issues():
    issues = []

    if Gdk.Display.get_default() is None:
        issues.append(
            "No graphical display is available. Start the player inside a GNOME or Wayland session."
        )

    if not hasattr(Gtk, "Video") or not hasattr(Gtk, "MediaFile"):
        issues.append("GTK 4 media widgets are not available in this PyGObject installation.")

    return issues


def print_startup_diagnostics(issues):
    gtk_major = Gtk.get_major_version()
    gtk_minor = Gtk.get_minor_version()
    gtk_micro = Gtk.get_micro_version()

    print("Startup dependency check failed.", file=sys.stderr)
    print(f"GTK version: {gtk_major}.{gtk_minor}.{gtk_micro}", file=sys.stderr)
    for issue in issues:
        print(f"- {issue}", file=sys.stderr)
    print(
        "Install GTK 4, PyGObject, and the GTK media backend package for your distribution "
        "(on Ubuntu 24.04 this is typically 'libgtk-4-media-gstreamer').",
        file=sys.stderr,
    )


