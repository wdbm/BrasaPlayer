        self.show_mouse_cursor()
        if self.fullscreen_controls_visible:
            if self.cursor_hide_timeout:
                GLib.source_remove(self.cursor_hide_timeout)
                self.cursor_hide_timeout = 0
        else:
            self.schedule_cursor_hide()

    def on_toggle_subtitles_action(self, *_args):
        if not self.subtitle_tracks:
            self.subtitles_enabled = False
            self.show_status_message("No external subtitles found")
            self.update_subtitle_label()
            return
        self.subtitles_enabled = not self.subtitles_enabled
        if self.subtitles_enabled and self.subtitle_track_index < 0:
            self.set_active_subtitle_track(0)
        self.show_status_message(
            f"Subtitles on: {self.subtitle_tracks[self.subtitle_track_index]['name']}"
            if self.subtitles_enabled and self.subtitle_track_index >= 0
            else "Subtitles off"
        )
        self.update_subtitle_label()

    def on_cycle_subtitles_action(self, *_args):
        if not self.subtitle_tracks:
            self.show_status_message("No external subtitles found")
            return
        next_index = 0 if self.subtitle_track_index < 0 else (
            (self.subtitle_track_index + 1) % len(self.subtitle_tracks)
        )
        self.set_active_subtitle_track(next_index)
        self.subtitles_enabled = True
        self.show_status_message(f"Subtitles: {self.subtitle_tracks[next_index]['name']}")
        self.update_subtitle_label()

